{
  "name": "rspack-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "scripts": {
    "dev": "rspack serve --mode=development",
    "build": "rspack build --mode=production",
    "prebuild": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "analyze-bundle": "node ../scripts/analyze-bundle.ts --name Rspack --html ./dist/index.html"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@rspack/cli": "latest",
    "@rspack/core": "latest",
    "@rspack/dev-server": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "rimraf": "latest",
    "typescript": "latest"
  }
}
