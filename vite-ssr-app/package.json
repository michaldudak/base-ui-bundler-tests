{
  "name": "vite-ssr-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build --outDir dist/client && vite build --ssr src/entry-server.tsx --outDir dist/server",
    "prebuild": "rimraf dist",
    "preview": "node server.js",
    "typecheck": "tsc -b",
    "analyze-bundle": "node --experimental-strip-types --disable-warning=ExperimentalWarning ../scripts/analyze-bundle.ts --name \"Vite SSR\" --html ./dist/client/index.html --server-bundle \"./dist/server/**/*.js\""
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "rimraf": "latest",
    "typescript": "latest"
  }
}
