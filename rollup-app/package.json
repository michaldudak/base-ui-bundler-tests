{
  "name": "rollup-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "prebuild": "rimraf dist",
    "typecheck": "tsc --noEmit",
