{
  "name": "base-ui-bundler-tests",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "scripts": {
    "sync-templates": "node scripts/sync-templates.mjs",
    "build": "pnpm run sync-templates && pnpm -r run build",
    "analyze-bundles": "node scripts/analyze-bundle.ts --workspace",
    "typecheck": "pnpm run sync-templates && pnpm -r run typecheck",
    "test": "pnpm run sync-templates && pnpm -r run test"
  },
  "packageManager": "pnpm@11.5.3",
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "process": "^0.11.10"
  }
}
