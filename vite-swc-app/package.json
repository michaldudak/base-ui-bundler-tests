{
  "name": "vite-swc-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "rimraf dist",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "analyze-bundle": "node ../scripts/analyze-bundle.ts --name 'Vite with SWC' --html ./dist/index.html"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react-swc": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "rimraf": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest"
  }
}
