    "@react-router/serve": "^7.17.0",
    "isbot": "latest",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.17.0",
    "@types/node": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "rimraf": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
