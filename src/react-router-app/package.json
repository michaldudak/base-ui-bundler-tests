{
  "name": "react-router-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "prebuild": "rimraf build .react-router",
    "start": "react-router-serve ./build/server/index.js",
