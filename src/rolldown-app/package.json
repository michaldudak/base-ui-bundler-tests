{
  "name": "rolldown-app",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "^22.18.0 || >=23.6.0"
  },
  "scripts": {
    "dev": "esbuild index.tsx --bundle --outfile=dist/index.js --servedir=.",
    "build": "rolldown -c rolldown.config.ts",
    "prebuild": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "analyze-bundle": "node ../../scripts/analyze-bundle.ts --name Rolldown --bundle dist/index.min.js"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "rolldown": "latest",
    "rimraf": "latest",
    "typescript": "latest"
  }
}
